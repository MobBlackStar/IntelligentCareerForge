<?xml version="1.0" encoding="UTF-8"?>

<!-- THE PASSPORTS (Imports) -->
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.careerforge.controller.MainLayoutController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="260.0" spacing="15.0" styleClass="kanban-column" style="-fx-background-radius: 0; -fx-padding: 30 15 15 15;">
            <children>

                <!-- THE FORGE LEVEL (Mutation 1) -->
                <VBox spacing="8.0" style="-fx-padding: 0 0 30 0;">
                    <children>
                        <Label text="FORGE LEVEL: ALPHA" textFill="#00f2fe">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <AnchorPane prefHeight="10.0" prefWidth="220.0" styleClass="forge-progress-bg">
                            <children>
                                <Region prefHeight="10.0" prefWidth="170.0" styleClass="forge-progress-fill" />
                            </children>
                        </AnchorPane>
                        <Label text="85% to Career Mastery" textFill="#8b949e">
                            <font><Font size="10.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <!-- NAVIGATION BUTTONS -->
                <Button onAction="#showWarRoom" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="🏠  WAR ROOM" />
                <Button onAction="#showArchetype" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="🎯  CHOOSE DESTINY" />
                <Button onAction="#showCVForge" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="📝  BUILD MASTER CV" />
                <Button onAction="#showPhantomSandbox" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="🧬  PHANTOM ATS" />
                <Button onAction="#showSkillTree" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="🌳  SKILL TREE" />

                <Region VBox.vgrow="ALWAYS" />

                <Button onAction="#showArena" prefHeight="50.0" prefWidth="230.0" style="-fx-background-color: #ff0044;" styleClass="action-button" text="🔥  THE ARENA" />
                <!-- THE ARSENAL BUTTON -->
                <Button onAction="#showArsenal" prefHeight="45.0" prefWidth="230.0" styleClass="action-button" text="🚀  THE ARSENAL" />
            </children>
        </VBox>
    </left>

    <!-- DYNAMIC CONTENT AREA (The Reactor Core) -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #0d1117;" />
    </center>
</BorderPane>