<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.careerforge.controller.WarRoomController">
    <children>
        <!-- HEADER -->
        <VBox layoutX="40.0" layoutY="30.0" spacing="5.0">
            <children>
                <Label text="THE WAR ROOM" textFill="#58a6ff">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <Label text="Manage your tactical job hunt" textFill="#8b949e" />
            </children>
        </VBox>

        <!-- MAGIC PASTE AREA (Top Right) -->
        <VBox layoutX="600.0" layoutY="20.0" spacing="10.0">
            <children>
                <TextArea fx:id="magicPasteArea" prefHeight="80.0" prefWidth="360.0" promptText="Paste messy LinkedIn job description here..." styleClass="text-area" />
                <Button onAction="#handleMagicPaste" prefHeight="40.0" prefWidth="360.0" styleClass="action-button" text="🦅 INJECT JOB OFFER" />
            </children>
        </VBox>

        <!-- KANBAN BOARD (Center) -->
        <HBox layoutX="40.0" layoutY="160.0" spacing="30.0">
            <children>
                <!-- TARGETED COLUMN -->
                <VBox prefHeight="500.0" prefWidth="280.0" styleClass="kanban-column">
                    <children>
                        <Label alignment="CENTER" prefHeight="50.0" prefWidth="280.0" text="TARGETED" textFill="#58a6ff">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <ScrollPane hbarPolicy="NEVER" prefHeight="450.0" prefWidth="280.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <VBox fx:id="targetedColumn" prefWidth="260.0" spacing="15.0" style="-fx-padding: 15;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- APPLIED COLUMN -->
                <VBox prefHeight="500.0" prefWidth="280.0" styleClass="kanban-column">
                    <children>
                        <Label alignment="CENTER" prefHeight="50.0" prefWidth="280.0" text="APPLIED" textFill="#facc15">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <ScrollPane hbarPolicy="NEVER" prefHeight="450.0" prefWidth="280.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <VBox fx:id="appliedColumn" prefWidth="260.0" spacing="15.0" style="-fx-padding: 15;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- INTERVIEWING COLUMN -->
                <VBox prefHeight="500.0" prefWidth="280.0" styleClass="kanban-column">
                    <children>
                        <Label alignment="CENTER" prefHeight="50.0" prefWidth="280.0" text="INTERVIEWING" textFill="#ef4444">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <ScrollPane hbarPolicy="NEVER" prefHeight="450.0" prefWidth="280.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <VBox fx:id="interviewingColumn" prefWidth="260.0" spacing="15.0" style="-fx-padding: 15;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>