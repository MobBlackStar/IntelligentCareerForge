<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="30.0" styleClass="root" stylesheets="@../css/style.css" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.careerforge.controller.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label text="THE CAREER FORGE" textFill="#58a6ff" style="-fx-font-size: 40; -fx-font-weight: bold; -fx-letter-spacing: 2;" />
                <Label text="Log in to your professional destiny" textFill="#8b949e" />
            </children>
        </VBox>

        <VBox maxWidth="380.0" spacing="20.0" styleClass="kanban-column" style="-fx-padding: 40; -fx-background-radius: 20;">
            <children>
                <VBox spacing="8.0">
                    <Label text="IDENTITY (EMAIL)" styleClass="form-label" textFill="#58a6ff" />
                    <!-- PLACEHOLDER ADDED HERE -->
                    <TextField fx:id="emailField" prefHeight="45.0" promptText="e.g. sarra@career.tn" styleClass="text-field" />
                </VBox>

                <VBox spacing="8.0">
                    <Label text="ACCESS KEY (PASSWORD)" styleClass="form-label" textFill="#58a6ff" />
                    <!-- SECURE DOTS ENABLED -->
                    <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="Enter your password" />
                </VBox>

                <Button onAction="#handleLogin" prefHeight="50.0" prefWidth="380.0" styleClass="action-button" text="ENTER THE MATRIX" />

                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Button onAction="#showRegister" text="CREATE ACCOUNT" style="-fx-background-color: transparent; -fx-text-fill: #00f2fe; -fx-font-weight: bold; -fx-cursor: hand;" />
                        <Button onAction="#showForgotPassword" text="FORGOT ACCESS?" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 11; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <Label fx:id="errorLabel" alignment="CENTER" prefWidth="500.0" wrapText="true" />
    </children>
</VBox>