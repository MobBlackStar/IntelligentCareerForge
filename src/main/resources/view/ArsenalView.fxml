<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" styleClass="arsenal-container" stylesheets="@../css/style.css" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.careerforge.controller.ArsenalController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label text="THE 1-CLICK ARSENAL" textFill="#58a6ff">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
                <Label text="[ STATUS: WEAPONIZING ]" textFill="#00f2fe" style="-fx-font-family: monospace;" />
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- COVER LETTER PANEL -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="📄 COVER LETTER (FORGED)" textFill="#8b949e" style="-fx-font-weight: bold;" />
                        <TextArea fx:id="letterArea" editable="false" prefHeight="500.0" styleClass="arsenal-text-area" wrapText="true" />
                        <Button onAction="#copyLetter" prefWidth="400.0" styleClass="copy-button" text="📋 COPY TO CLIPBOARD" />
                    </children>
                </VBox>

                <!-- LINKEDIN DM PANEL -->
                <VBox spacing="10.0" prefWidth="350.0">
                    <children>
                        <Label text="💬 LINKEDIN COLD DM" textFill="#8b949e" style="-fx-font-weight: bold;" />
                        <TextArea fx:id="dmArea" editable="false" prefHeight="200.0" styleClass="arsenal-text-area" wrapText="true" />
                        <Button onAction="#copyDM" prefWidth="350.0" styleClass="copy-button" text="📋 COPY DM" />

                        <Region VBox.vgrow="ALWAYS" />
                        <Button onAction="#generateNewArsenal" prefHeight="60.0" prefWidth="350.0" styleClass="action-button" text="🔄 RE-FORGE ARSENAL" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>